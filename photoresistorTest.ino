// 螤蟻蠈纬蟻伪碌碌伪 纬喂伪 伪蟺位蠈 蟺蔚喂蟻伪碌伪蟿喂蟽碌蠈 碌蔚 蠁蠅蟿慰伪谓蟿喂蟽蟿维蟿畏
int a; // 蔚未蠋 胃伪 魏蟻伪蟿维碌蔚 蟿畏谓 蟿喂碌萎 蟺慰蠀 未喂伪尾维味慰蠀碌蔚 伪蟺蠈 蟿慰谓 蠁蠅蟿慰伪谓蟿喂蟽蟿维蟿畏
float b; // 蔚未蠋 胃伪 伪蟺慰胃畏魏蔚蠉慰蠀碌蔚 蟿畏谓 蟿维蟽畏 蟺慰蠀 苇蠂蔚喂 慰 蠁蠅蟿慰伪谓蟿喂蟽蟿维蟿畏蟼 蟽蟿伪 维魏蟻伪 蟿慰蠀
float c; // 蔚未蠋 胃伪 伪蟺慰胃畏魏蔚蠉慰蠀碌蔚 蟿畏谓 蟿喂碌萎 蟿畏蟼 伪谓蟿委蟽蟿伪蟽畏蟼 蟿慰蠀 蠁蠅蟿慰伪谓蟿喂蟽蟿维蟿畏
void setup() {
 Serial.begin(9600); // 尉蔚魏喂谓维碌蔚 蟿慰 蟽蔚喂蟻喂伪魏蠈 碌蠈谓喂蟿慰蟻 蟿慰蠀 Arduino IDE
 }
 
 void loop() {
 a=analogRead(A0); // 未喂维尾伪蟽蔚 蟿畏谓 蟿喂碌萎 蟿畏蟼 蟿维蟽畏蟼 蟽蟿畏谓 伪谓伪位慰纬喂魏萎 蔚委蟽慰未慰 A0
 Serial.print("韦喂碌萎: ");
 Serial.print(a); // 伪蟺蔚喂魏蠈谓喂蟽蔚 蟿畏谓 蟿喂碌萎 蟿畏蟼 a 蟽蟿慰 蟽蔚喂蟻喂伪魏蠈 碌蠈谓喂蟿慰蟻 蟿慰蠀 Arduino ID螘
 Serial.print("\t");

 b=a*5.0/1023; // 蠀蟺慰位蠈纬喂蟽蔚 蟿畏谓 蟿喂碌萎 蟿畏蟼 蟿维蟽畏蟼 蟽蟿伪 维魏蟻伪 蟿慰蠀 蠁蠅蟿慰伪谓蟿喂蟽蟿维蟿畏 (伪谓蟿喂蟽蟿慰喂蠂委伪: 1023 --> 5V)
 Serial.print("韦维蟽畏: ");
 Serial.print(b); // 伪蟺蔚喂魏蠈谓喂蟽蔚 蟿畏谓 蟿喂碌萎 蟿畏蟼 蟿维蟽畏蟼
 Serial.print(" V \t");
 c=b*10.0/(5-b); // 蠀蟺慰位蠈纬喂蟽蔚 蟿畏谓 伪谓蟿委蟽蟿伪蟽畏 蟿慰蠀 蠁蠅蟿慰伪谓蟿喂蟽蟿维蟿畏 蟽蔚 k惟

 Serial.print(c);
 Serial.println(" k惟");

 delay(500); // 蟺蔚蟻委碌蔚谓蔚 蔚未蠋 0,5 未蔚蠀蟿蔚蟻蠈位蔚蟺蟿慰
}
